# Apache Configuration for React SPA with PHP API Fallbacks
RewriteEngine On
RewriteBase /
# Permanent redirect for Khajuraho Temple India guide
RewriteRule ^khajuraho-temple-india$ /guides/khajuraho-temple-india [R=301,L]

RewriteRule ^api/save-categories/?$ api-save-categories.php [L]
RewriteRule ^api/save-tours/?$ api-save-tours.php [L]
RewriteRule ^api/save-guides/?$ api-save-guides.php [L]
RewriteRule ^api/save-leads$ api-save-leads.php [L]
RewriteRule ^api/train-queries$ api-train-queries.php [L]
RewriteRule ^api/save-review$ api-save-review.php [L]
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-l
RewriteRule . /index.html [L]
