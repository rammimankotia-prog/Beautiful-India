RewriteEngine On

# Route categorization save request to PHP fallback for environments without Node.js
RewriteRule ^api/save-categories$ api-save-categories.php [L]

# For React Router SPA support if serving via Apache
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
